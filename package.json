{
  "name": "anystone",
  "version": "3.0.18",
  "author": "weiyajun <weiyajun@megvii.com>",
  "description": "A tool to improve the viewing of pictures and videos by researchers",
  "homepage": "https://github.com/sumching51us-gif/macstone",
  "license": "Apache License Version 2.0",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "preview": "vite preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "extraFiles": [],
    "publish": [
      {
        "provider": "github",
        "private": false,
        "repo": "macstone",
        "owner": "sumching51us-gif",
        "releaseType": "release"
      }
    ],
    "productName": "AnyStone",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "appId": "com.anystone.anystone",
    "copyright": "Copyright (c) 2024 Megvii Inc. All rights reserved.",
    "directories": {
      "output": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      "LICENSE",
      "COPYRIGHT",
      "CONTRIBUTOR LICENSE AGREEMENT"
    ],
    "dmg": {
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ]
    },
    "mac": {
      "icon": "build/icons/logo.icns",
      "identity": "-",
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "build/icons/logo.ico"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.8.0",
    "chokidar": "^4.0.0",
    "dayjs": "^1.11.0",
    "electron-log": "^5.3.0",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.0",
    "element-plus": "^2.9.0",
    "file-saver": "^2.0.5",
    "image-size": "^2.0.2",
    "jszip": "^3.10.0",
    "lodash": "^4.17.21",
    "mediainfo.js": "^0.3.0",
    "path-browserify": "^1.0.1",
    "pinia": "^3.0.4",
    "sortablejs": "^1.15.0",
    "swiper": "^11.0.0",
    "utif2": "^4.1.0",
    "viewerjs": "^1.11.0",
    "vue": "^3.5.0",
    "vue-draggable-next": "^2.2.0",
    "vue-i18n": "^9.14.0",
    "vue-lazyload": "^3.0.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "electron": "^30.5.1",
    "electron-builder": "^25.0.0",
    "sass": "^1.80.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
